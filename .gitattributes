# Normalize line endings: store text files with LF in the repo
* text=auto eol=lf

# Explicit text types
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.xml   text eol=lf
*.txt   text eol=lf
*.md    text eol=lf

# Binary assets (never normalize)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.webp  binary
*.gif   binary
